<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f0f">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:text="Phone Agent"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Remote access from anywhere via ngrok"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Step 1 -->
        <TextView
            android:text="Step 1 — Get your free ngrok authtoken"
            android:textSize="14sp"
            android:textColor="#cccccc"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Visit ngrok.com → Sign up free → Dashboard → Your Authtoken → Copy it"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Token input -->
        <EditText
            android:id="@+id/etNgrokToken"
            android:hint="Paste your ngrok authtoken here"
            android:textColorHint="#555555"
            android:textColor="#ffffff"
            android:background="@drawable/input_bg"
            android:padding="14dp"
            android:textSize="13sp"
            android:inputType="textVisiblePassword"
            android:layout_marginBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Step 2 -->
        <TextView
            android:text="Step 2 — Start the agent"
            android:textSize="14sp"
            android:textColor="#cccccc"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnStart"
            android:text="Start Agent"
            android:backgroundTint="#2563eb"
            android:textColor="#ffffff"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:textSize="15sp"/>

        <Button
            android:id="@+id/btnStop"
            android:text="Stop Agent"
            android:backgroundTint="#374151"
            android:textColor="#ffffff"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="28dp"
            android:textSize="14sp"/>

        <!-- Status card -->
        <LinearLayout
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Status"
                android:textSize="11sp"
                android:textColor="#6b7280"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvStatus"
                android:text="Not started"
                android:textSize="14sp"
                android:textColor="#d1d5db"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- URL card -->
        <LinearLayout
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Dashboard URL (use in web dashboard)"
                android:textSize="11sp"
                android:textColor="#6b7280"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvUrl"
                android:text="—"
                android:textSize="13sp"
                android:textColor="#60a5fa"
                android:textIsSelectable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Step 3 info -->
        <TextView
            android:text="Step 3 — Open web dashboard"
            android:textSize="14sp"
            android:textColor="#cccccc"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Open the index.html file from the web-dashboard folder on your laptop/PC. Enter the URL shown above and click Connect."
            android:textSize="12sp"
            android:textColor="#888888"
            android:lineSpacingExtra="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>
